{
    "audio": {
        "step": 5,
        "min": 0,
        "max": 100,
        "default": 50,
        "check_timeout": 10
    },
    "sfx": {
        "path": "sfx",
        "vol_min": 0,
        "vol_max": 150
    },
    "overlay": {
        "timeout": 3,
        "corner": "bottom-right",
        "offset_x": 20,
        "offset_y": 50,
        "gifs_path": "gifs",
        "gifs_enabled": true,
        "vhs_enabled": true,
        "theme": {
            "bg": "#222222",
            "border": "#444444",
            "progress_bg": "#333333",
            "progress_fill": "#ffffff",
            "text_status": {"family": "Segoe UI", "size": 20, "color": "#ffffff"},
            "text_station": {"family": "Segoe UI", "size": 12, "weight": "bold", "color": "#f0f0f0"},
            "text_category": {"family": "Segoe UI", "size": 10, "color": "#cccccc"},
            "text_info": {"family": "Segoe UI", "size": 9, "color": "#aaaaaa"},
            "gradient_base": "#222222",
            "gradient_highlight": "#5c5c5c",
            "gradient_divisor": 4,
            "padding": {
                "padx": 14,
                "pady_top": 10,
                "pady_gap": 30,
                "pady_station": 4,
                "pady_cat": 2,
                "pady_info": 4,
                "pady_progress": 6,
                "pady_bottom": 10
            }
        }
    },
    "logging": {
        "path": "logs",
        "enabled": false
    },
    "proxy": ""
}